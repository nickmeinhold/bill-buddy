#!/bin/bash

echo "Running pre-commit checks..."

# Check if there are staged Dart files
STAGED_DART_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.dart$' || true)

if [ -z "$STAGED_DART_FILES" ]; then
    echo "No Dart files staged, skipping checks."
    exit 0
fi

# Run dart format on staged files
echo "Checking format..."
dart format --set-exit-if-changed $STAGED_DART_FILES
FORMAT_EXIT=$?

if [ $FORMAT_EXIT -ne 0 ]; then
    echo ""
    echo "❌ Format check failed. Run 'dart format .' to fix."
    exit 1
fi

# Run flutter analyze
echo "Running analyzer..."
flutter analyze --fatal-infos
ANALYZE_EXIT=$?

if [ $ANALYZE_EXIT -ne 0 ]; then
    echo ""
    echo "❌ Analysis failed. Fix the issues above before committing."
    exit 1
fi

echo "✅ Pre-commit checks passed!"
exit 0
